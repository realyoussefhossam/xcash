#!/bin/bash

set -o errexit
set -o pipefail
set -o nounset

cd /app/signer

eval "$(python /app/performance.py shell-env signer)"

# signer 数据库迁移由 scripts/upgrade.sh 统一执行，避免容器启动时绕过迁移演练入口。

# 上线兜底：检测到尚未应用的迁移即立即退出，强制运维先执行 scripts/upgrade.sh，
# 避免 signer 容器连到陈旧 schema 产生运行时错误。
python manage.py migrate --check

exec gunicorn config.wsgi:application \
  --bind 0.0.0.0:8000 \
  --chdir=/app/signer \
  --workers "${SIGNER_GUNICORN_WORKERS}"
